from sympy import isprime

diagonals = [1, 3, 5, 7, 9]
length = 3
add = 2
primes = 3
total = 5

while primes/total >= 0.1:
    add += 2
    lapse = 0

    while lapse < 4:
        diagonals.append(diagonals[-1] + add)
        if isprime(diagonals[-1]):
            primes += 1
        total += 1
        lapse += 1

    length += 2

print(f"Answer to Problem 58: {length}") # SOLVED: 26241
